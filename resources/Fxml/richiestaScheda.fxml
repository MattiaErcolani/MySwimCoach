<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.RichiestaSchedaGui"
            style="-fx-background-color: #0A1628;">

    <!-- PANNELLO SINISTRO -->
    <Rectangle layoutX="0" layoutY="0" width="320" height="500" fill="#0A1628"/>

    <Text text="MySwimCoach" layoutX="60" layoutY="200"
          fill="white" strokeType="OUTSIDE" strokeWidth="0.0">
        <font><Font name="System Bold" size="24.0"/></font>
    </Text>
    <Text text="Il tuo allenatore di nuoto personale"
          layoutX="55" layoutY="225" fill="#90A4AE"
          strokeType="OUTSIDE" strokeWidth="0.0">
        <font><Font size="12.0"/></font>
    </Text>

    <ImageView layoutX="60" layoutY="235" fitWidth="200" fitHeight="160" preserveRatio="true">
        <image>
            <Image url="@/Images/LogoNuotatore2.png"/>
        </image>
    </ImageView>

    <!-- SEPARATORE -->
    <Line startX="0" startY="0" endX="0" endY="500"
          layoutX="320" stroke="#1E3A5F"/>

    <!-- PANNELLO DESTRO -->
    <Rectangle layoutX="320" layoutY="0" width="480" height="500" fill="#0D1F3C"/>

    <!-- Bottone torna indietro -->
    <Button fx:id="btnTornaMenu" layoutX="370" layoutY="20"
            prefWidth="100" prefHeight="32"
            text="← Menu"
            onMouseClicked="#tornaMenu"
            style="-fx-background-color: transparent; -fx-text-fill: #64B5F6; -fx-font-size: 12px; -fx-border-color: #1E3A5F; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <!-- Titolo -->
    <Text text="Richiedi Scheda di Nuoto" layoutX="370" layoutY="80"
          fill="white" strokeType="OUTSIDE" strokeWidth="0.0">
        <font><Font name="System Bold" size="22.0"/></font>
    </Text>

    <!-- Istruttore -->
    <Text text="ISTRUTTORE" layoutX="370" layoutY="105"
          fill="#90A4AE" strokeType="OUTSIDE" strokeWidth="0.0">
        <font><Font size="11.0"/></font>
    </Text>
    <ChoiceBox fx:id="istruttoreChoice" layoutX="370" layoutY="111"
               prefWidth="380" prefHeight="36"
               style="-fx-background-color: #0A1628; -fx-text-fill: white; -fx-border-color: #1E3A5F; -fx-border-radius: 8; -fx-background-radius: 8;"/>

    <!-- Livello -->
    <Text text="IL TUO LIVELLO" layoutX="370" layoutY="165"
          fill="#90A4AE" strokeType="OUTSIDE" strokeWidth="0.0">
        <font><Font size="11.0"/></font>
    </Text>
    <ChoiceBox fx:id="livelloChoice" layoutX="370" layoutY="171"
               prefWidth="380" prefHeight="36"
               style="-fx-background-color: #0A1628; -fx-text-fill: white; -fx-border-color: #1E3A5F; -fx-border-radius: 8; -fx-background-radius: 8;"/>

    <!-- Info -->
    <Text text="INFO AGGIUNTIVE" layoutX="370" layoutY="225"
          fill="#90A4AE" strokeType="OUTSIDE" strokeWidth="0.0">
        <font><Font size="11.0"/></font>
    </Text>
    <TextField fx:id="infoField" layoutX="370" layoutY="231"
               prefWidth="380" prefHeight="36"
               promptText="Es. obiettivi, disponibilità, note..."
               style="-fx-background-color: #0A1628; -fx-text-fill: white; -fx-prompt-text-fill: #455A75; -fx-border-color: #1E3A5F; -fx-border-radius: 8; -fx-background-radius: 8;"/>

    <!-- Messaggio status -->
    <Label fx:id="statusLabel" layoutX="370" layoutY="290"
           prefWidth="380" text=""
           style="-fx-font-size: 12px;"/>

    <!-- Bottone invia -->
    <Button fx:id="btnInvia" layoutX="370" layoutY="320"
            prefWidth="380" prefHeight="42"
            text="📤 Invia Richiesta"
            onMouseClicked="#inviaRichiesta"
            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

</AnchorPane>